PORT=3000
# Production: set for secure cookies, compression, static cache hints (see server.js).
# NODE_ENV=production
#
# Hops behind reverse proxy (nginx). Default 1. Use 2 if another proxy sits in front.
# TRUST_PROXY=1

# VPS behind nginx: bind only on loopback (recommended). Omit for local dev on all interfaces.
# LISTEN_HOST=127.0.0.1
#
# Session cookies: in production, Secure cookies are used by default (HTTPS only).
# If you serve the app over plain HTTP (e.g. http://IP:8888 before TLS), set:
# COOKIE_SECURE=false
# Remove or set true once users hit the site only via HTTPS.
# First-time admin (created only if no admin exists yet)
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme-admin-2026

# Vercel / production: set Postgres connection string (Neon free tier works well).
# On Vercel, SQLite is not used — the serverless filesystem cannot persist a local DB file.
# Example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Optional: force Postgres locally too (same as Vercel)
# DATABASE_URL=postgresql://...

# Stripe (optional). A Payment Link is hosted entirely by Stripe — no “callback” URL on this app.
# If you leave these empty, use Admin → +30 days (or set dates) after you confirm payment in Stripe.
# If you set both, point a Stripe webhook to https://<your-host>/api/stripe/webhook to extend access automatically.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional override for SQLite file
# SQLITE_PATH=./data/app.db
#
# Self-hosted: optional server-side copy of garment/design images to `data/uploads/` (see /api/blob-upload/*).
# Disabled automatically on Vercel. Set to disable on VPS too:
# DISABLE_SERVER_UPLOADS=1
